flowchart TD
    subgraph INPUT["Input"]
        A["1. Prompt"]
    end

    subgraph THINK["Thinking"]
        B["2. Context"]
        C["3. Plan"]
        D["4. Reason"]
    end

    subgraph SAFETY["Safety"]
        E{"5. Permission Gate"}
        HITL["Human approval"]
        V{"6. Verify"}
    end

    subgraph DO["Doing"]
        F["7. Act"]
        G{"8. Observe"}
        RETRY["Retry"]
        SH["Self-Heal"]
    end

    subgraph CHECK["Termination"]
        H{"9. Done?"}
    end

    subgraph REMEMBER["Remembering"]
        I["10. Store"]
        J["Memory"]
        PM["Persistent Memory"]
    end

    A --> B --> C --> D --> E
    E -->|allowed| V
    E -->|high-stakes| HITL
    HITL -->|approved| V
    HITL -->|rejected| C
    V -->|passes| F
    V -->|fails| C
    F --> G
    G -->|error| RETRY
    RETRY --> F
    G -->|plan wrong| C
    G -->|self-healable| SH
    SH --> F
    G -->|success| H
    H -->|not done| I
    H -->|done| I
    I --> J
    J --> PM
    PM -.next session.-> B
    J -.next cycle.-> C

    style INPUT fill:#1a1a2e,color:#fff,stroke:#e94560
    style THINK fill:#16213e,color:#fff,stroke:#0f3460
    style SAFETY fill:#3d0000,color:#fff,stroke:#e94560
    style DO fill:#0f3460,color:#fff,stroke:#e94560
    style CHECK fill:#16213e,color:#fff,stroke:#0f3460
    style REMEMBER fill:#1a1a2e,color:#fff,stroke:#0f3460
