flowchart TD
    A["Task Completed"] --> B["Record Task"]
    B --> C["Extract Patterns"]
    C --> D{"Enough Data?"}
    D -->|No| E["Wait for More"]
    D -->|Yes| F["Analyze Successes"]
    F --> G["Analyze Failures"]
    G --> H["Optimize Strategy"]
    H --> I["Update Strategy Store"]
    I --> J["Generate Report"]
