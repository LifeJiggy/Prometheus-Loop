flowchart TD
    A["Task Started"] --> B["Start Trace"]
    B --> C["Record Decision"]
    C --> D["Record Reasoning"]
    D --> E["Task Completed"]
    E --> F["End Trace"]
    F --> G["Analyze Outcome"]
    G --> H["Extract Lessons"]
    H --> I["Update Confidence"]
    I --> J["Generate Insights"]
