flowchart TD
    A["Error Occurred"] --> B["Capture Error"]
    B --> C["Analyze Error"]
    C --> D["Gather Code Context"]
    D --> E{"Known Fix?"}
    E -->|Yes| F["Apply Known Fix"]
    E -->|No| G["LLM Diagnose"]
    G --> H["Generate Fix"]
    H --> I["Apply Fix"]
    F --> I
    I --> J["Verify Fix"]
    J -->|Success| K["Store Solution"]
    J -->|Failed| L["Revert Fix"]
    L --> M["Escalate"]
