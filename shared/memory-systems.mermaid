flowchart TD
    A["New Content"] --> B{"Should Remember?"}
    B -->|No| C["Discard"]
    B -->|Yes| D["Score Relevance"]
    D --> E{"Above Threshold?"}
    E -->|No| C
    E -->|Yes| F{"Memory Full?"}
    F -->|No| G["Store"]
    F -->|Yes| H["Consolidate"]
    H --> I["Evict Old"]
    I --> G
    G --> J["Update Index"]
    J --> K["Ready for Recall"]
