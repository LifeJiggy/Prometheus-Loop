flowchart TD
    A["Communication Need"] --> B{"Pattern?"}
    B -->|Sync| C["Request-Response"]
    B -->|Async| D["Publish-Subscribe"]
    B -->|Decoupled| E["Message Queue"]
    B -->|Shared| F["Blackboard"]
    C --> G["Process"]
    D --> G
    E --> G
    F --> G
    G --> H{"Conflict?"}
    H -->|Yes| I["Resolve"]
    H -->|No| J["Return Result"]
    I --> J
